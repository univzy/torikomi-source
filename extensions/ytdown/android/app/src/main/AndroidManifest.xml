<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:icon="@drawable/icon_ytdown"
        android:label="Torikomi: YTDown">

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@android:style/Theme.NoDisplay" />

        <provider
            android:name=".ExtensionProvider"
            android:authorities="torikomi.extension.ytdown"
            android:exported="true" />

        <meta-data android:name="torikomi.extension" android:value="true" />
        <meta-data android:name="torikomi.extension.id" android:value="ytdown" />
        <meta-data android:name="torikomi.extension.platform" android:value="ytdown" />
        <meta-data android:name="torikomi.extension.platformName" android:value="YTDown" />
        <meta-data android:name="torikomi.extension.version" android:value="1.0.0" />
        <meta-data android:name="torikomi.extension.downloader" android:value="YTDown" />
        <meta-data android:name="torikomi.extension.description" android:value="Downloader YouTube via YTDown (video MP4 dan audio MP3/M4A)." />
        <meta-data android:name="torikomi.extension.lang" android:value="multi" />
        <meta-data android:name="torikomi.extension.icon" android:value="icon-ytdown" />
        <meta-data android:name="torikomi.extension.color" android:value="#FF0000" />
        <meta-data android:name="flutterEmbedding" android:value="2" />
    </application>

</manifest>
