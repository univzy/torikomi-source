<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:icon="@drawable/icon_snapsave_facebook"
        android:label="Torikomi: Facebook">

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@android:style/Theme.NoDisplay" />

        <provider
            android:name=".ExtensionProvider"
            android:authorities="torikomi.extension.snapsave_facebook"
            android:exported="true" />

        <meta-data android:name="torikomi.extension" android:value="true" />
        <meta-data android:name="torikomi.extension.id" android:value="snapsave_facebook" />
        <meta-data android:name="torikomi.extension.platform" android:value="facebook" />
        <meta-data android:name="torikomi.extension.platformName" android:value="Facebook" />
        <meta-data android:name="torikomi.extension.version" android:value="1.0.0" />
        <meta-data android:name="torikomi.extension.downloader" android:value="SnapSave" />
        <meta-data android:name="torikomi.extension.description" android:value="SnapSave downloader for Facebook videos and reels." />
        <meta-data android:name="torikomi.extension.urlPlaceholder" android:value="https://www.facebook.com/watch?v=1234567890" />
        <meta-data android:name="torikomi.extension.lang" android:value="multi" />
        <meta-data android:name="torikomi.extension.icon" android:value="snapsave_facebook" />
        <meta-data android:name="torikomi.extension.color" android:value="#1877F2" />

    </application>

</manifest>
