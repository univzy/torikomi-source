<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:icon="@drawable/icon_soundloadmate"
        android:label="Torikomi: SoundCloud">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@android:style/Theme.NoDisplay">
            <intent-filter>
                <action android:name="com.torikomi.extension.action.DISCOVERY" />
            </intent-filter>
        </activity>

        <provider
            android:name=".ExtensionProvider"
            android:authorities="torikomi.extension.soundloadmate"
            android:exported="true" />

        <meta-data android:name="torikomi.extension"              android:value="true" />
        <meta-data android:name="torikomi.extension.id"           android:value="soundloadmate" />
        <meta-data android:name="torikomi.extension.platform"     android:value="soundcloud" />
        <meta-data android:name="torikomi.extension.platformName" android:value="SoundCloud" />
        <meta-data android:name="torikomi.extension.version"      android:value="1.0.1" />
        <meta-data android:name="torikomi.extension.downloader"   android:value="SoundCloudMate" />
        <meta-data android:name="torikomi.extension.description"  android:value="Download SoundCloud tracks and playlists as MP3 via SoundCloudMate." />
        <meta-data android:name="torikomi.extension.urlPlaceholder" android:value="https://soundcloud.com/artist/track" />
        <meta-data android:name="torikomi.extension.lang"  android:value="multi" />
        <meta-data android:name="torikomi.extension.icon"  android:value="soundloadmate" />
        <meta-data android:name="torikomi.extension.color" android:value="#FF5500" />
        <meta-data android:name="flutterEmbedding" android:value="2" />
    </application>

</manifest>
